---
import Layout from "../layouts/Layout.astro";

// Server-side render kanıtı: bu blok her istekte Cloudflare Workers üzerinde çalışır.
const renderedAt = new Date().toLocaleString("tr-TR", {
  timeZone: "Europe/Istanbul",
  dateStyle: "medium",
  timeStyle: "medium",
});
const base = import.meta.env.BASE_URL;
---

<Layout title="Sestek Demo Hub">
  <main>
    <header>
      <p class="eyebrow">Webflow Cloud</p>
      <h1>Sestek <span>Demo Hub</span></h1>
      <p class="lead">
        Bu sayfa, Webflow sitesine mount edilmiş bir Astro uygulamasından
        server-side render ediliyor. Demo sayfaları ve özel servisler buraya
        eklenecek.
      </p>
    </header>

    <section class="cards">
      <article class="card">
        <h2>Server-side render</h2>
        <p>
          Bu istek <strong>{renderedAt}</strong>'de Cloudflare Workers üzerinde
          işlendi — statik değil, her ziyarette yeniden üretiliyor.
        </p>
      </article>

      <article class="card">
        <h2>API endpoint örneği</h2>
        <p>
          <a href={`${base}/api/hello`}><code>{base}/api/hello</code></a> canlı bir
          JSON servisi — form işleme, hesaplayıcı, entegrasyon gibi servislerin
          temeli.
        </p>
      </article>

      <article class="card">
        <h2>Sıradaki demolar</h2>
        <p>
          Yeni bir demo eklemek için <code>src/pages/</code> altına bir
          <code>.astro</code> dosyası koymak yeterli — route otomatik oluşur.
        </p>
      </article>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 60rem;
    margin: 0 auto;
    padding: clamp(3rem, 8vw, 6rem) 1.5rem 4rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brand-turquoise);
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  h1 span {
    background: linear-gradient(
      100deg,
      var(--brand-turquoise),
      var(--brand-lilac) 45%,
      var(--brand-magenta)
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .lead {
    max-width: 42rem;
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-dim);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1rem;
    margin-top: 3rem;
  }

  .card {
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    background: var(--surface);
  }

  .card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
  }

  .card p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-dim);
  }

  .card a {
    color: var(--brand-turquoise);
    text-decoration: none;
  }

  .card a:hover {
    text-decoration: underline;
  }

  code {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.85em;
  }
</style>
